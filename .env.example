# Copy to .env and adjust as needed. .env is gitignored.
# Backend
JWT_SIGNING_KEY=dev-only-secret-with-more-than-thirty-two-chars-of-entropy
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# Database (matches docker-compose.yml)
DATABASE_URL=jdbc:postgresql://localhost:5432/soql_explorer
DATABASE_USERNAME=soql_explorer
DATABASE_PASSWORD=soql_explorer

# Salesforce Connected App — required to exercise the OAuth Web Server Flow end-to-end.
# Leave blank to boot without a Connected App (OAuth calls will return a typed error).
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_REDIRECT_URI=http://localhost:8080/connections/oauth/callback
SF_SPA_REDIRECT=http://localhost:5173/connections
SF_SCOPES=api refresh_token offline_access
SF_API_VERSION=v60.0
# Base64-encoded 32 random bytes used to AES-GCM encrypt SF refresh tokens at rest.
# Generate locally with: openssl rand -base64 32
SF_REFRESH_TOKEN_ENCRYPTION_KEY=dev-only-32-byte-key-please-change-soon
